# =============================================================================
# ИИ-тьютор для СПО — Переменные окружения для Docker
# =============================================================================
# Инструкция:
#   cp .env.docker.example .env
#   # Отредактируйте .env под ваше окружение
#   docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Модель
# -----------------------------------------------------------------------------

# Путь к базовой модели.
# Можно указать ID из Hugging Face Hub или локальный путь (если модель
# предварительно скачана в volume model-data).
# Примеры:
#   mistralai/Mistral-Small-24B-Instruct-2501
#   /app/.cache/huggingface/hub/models--mistralai--Mistral-Small-24B-Instruct-2501/snapshots/...
MODEL_PATH=mistralai/Mistral-Small-24B-Instruct-2501

# Путь к LoRA-адаптерам (опционально).
# Оставьте пустым, если используете базовую модель без адаптеров.
# Пример: /app/lora-adapter
ADAPTER_PATH=

# Стратегия размещения модели по устройствам.
# «auto» — автоматически распределит по доступным GPU/CPU.
# «cuda» — принудительно на GPU.
# «cpu» — только CPU (медленно, для отладки).
DEVICE_MAP=auto

# Токен Hugging Face (нужен для gated-моделей).
# Получить можно здесь: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------

# URL для подключения к Redis (брокер сообщений и хранилище результатов).
# В Docker Compose сервис Redis доступен по имени хоста «redis».
REDIS_URL=redis://redis:6379/0

# Логирование воркера Celery (DEBUG/INFO/WARNING/ERROR).
CELERY_LOG_LEVEL=INFO

# Мягкий лимит времени выполнения задачи (секунды).
# После превышения задача получает SIGTERM.
CELERY_TASK_SOFT_TIME_LIMIT=120

# Жёсткий лимит времени выполнения задачи (секунды).
# После превышения задача убивается SIGKILL.
CELERY_TASK_TIME_LIMIT=180

# -----------------------------------------------------------------------------
# API / FastAPI
# -----------------------------------------------------------------------------

# Порт, на котором API принимает входящие соединения.
API_PORT=8000

# Разрешённые источники CORS (через запятую).
# Добавьте домен вашего фронтенда для работы из браузера.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Ключ для защиты API (опционально).
# Если задан, запросы должны содержать заголовок X-API-Key.
API_KEY=

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------

# Уровень логирования приложения.
# Для отладки используйте DEBUG, для production — INFO или WARNING.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Порт Redis для проброса на хост (для внешних клиентов, например RedisInsight)
# -----------------------------------------------------------------------------
REDIS_PORT=6379
