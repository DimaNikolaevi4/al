# =============================================================================
# ИИ-тьютор для СПО — Конфигурация окружения
# =============================================================================
# Скопируйте этот файл в .env и заполните ваши значения.
# НИКОГДА не коммитьте файл .env в систему контроля версий!
# =============================================================================

# -----------------------------------------------------------------------------
# Конфигурация модели
# -----------------------------------------------------------------------------

# Путь к базовой модели (ID Hugging Face или локальный путь)
# Примеры:
#   - Hugging Face: mistralai/Mistral-Small-24B-Instruct-2501
#   - Локальный: /mnt/models/mistral-small-24b
MODEL_PATH=mistralai/Mistral-Small-24B-Instruct-2501

# Путь к LoRA-адаптерам (опционально, оставьте пустым для только базовой модели)
# Пример: ./lora-tutors-adapter
ADAPTER_PATH=

# Токен Hugging Face (требуется для приватных или gated моделей)
# Получите токен: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# Конфигурация логирования
# -----------------------------------------------------------------------------

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к файлу логов (опционально, по умолчанию tutor.log)
LOG_FILE=tutor.log

# -----------------------------------------------------------------------------
# Конфигурация инференса
# -----------------------------------------------------------------------------

# Максимальное количество токенов для генерации в одном запросе
MAX_TOKENS=2048

# Температура сэмплирования (0.1 - 2.0, ниже = более детерминированно)
TEMPERATURE=0.7

# Порог nucleus (top-p) сэмплирования
TOP_P=0.9

# Top-k сэмплирование (0 = отключено)
TOP_K=50

# -----------------------------------------------------------------------------
# Конфигурация GPU
# -----------------------------------------------------------------------------

# Максимальная память на GPU (опционально)
# Пример: {"0": "20GB", "1": "20GB"}
MAX_MEMORY=

# Стратегия размещения устройств: auto, cuda, cpu
DEVICE_MAP=auto

# -----------------------------------------------------------------------------
# API сервер (FastAPI)
# -----------------------------------------------------------------------------

# Хост и порт API
API_HOST=0.0.0.0
API_PORT=8000

# Секретный ключ для аутентификации API
SECRET_KEY=замените-на-надёжный-случайный-ключ

# Разрешённые источники CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Ограничение частоты запросов (запросов в минуту)
RATE_LIMIT=60

# Максимальная длина лекции для генерации конспекта (символов)
MAX_LECTURE_LENGTH=50000

# Таймаут генерации (секунды, 0 = без лимита)
GENERATION_TIMEOUT=120

# Degraded mode: запускать сервер даже если модель не загружена
DEGRADED_MODE=true

# -----------------------------------------------------------------------------
# Celery + Redis (очередь задач)
# -----------------------------------------------------------------------------

# URL брокера Celery
REDIS_URL=redis://localhost:6379/0

# Время жизни задачи в очереди (секунды)
CELERY_TASK_EXPIRES=300

# Hard time limit для задачи (секунды)
CELERY_TASK_TIME_LIMIT=180

# Soft time limit (предупреждение за N секунд до hard limit)
CELERY_TASK_SOFT_TIME_LIMIT=150

# Результат задачи хранится N секунд после завершения
CELERY_RESULT_EXPIRES=3600

# -----------------------------------------------------------------------------
# Интеграция с Moodle
# -----------------------------------------------------------------------------

# URL сайта Moodle (заполняется в настройках плагина)
MOODLE_URL=

# Токен Web Service Moodle (заполняется в настройках плагина)
MOODLE_TOKEN=

# URL API ИИ-тьютора (изменить на реальный хост при деплое)
AITUTOR_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Мониторинг (Prometheus + Grafana)
# -----------------------------------------------------------------------------

# Включить экспорт метрик Prometheus
ENABLE_METRICS=true

# Порт для Prometheus metrics endpoint
METRICS_PORT=9090

# Путь для metrics endpoint
METRICS_PATH=/metrics
