# =============================================================================
# ИИ-тьютор для СПО — Конфигурация окружения
# =============================================================================
# Скопируйте этот файл в .env и заполните ваши значения.
# НИКОГДА не коммитьте файл .env в систему контроля версий!
# =============================================================================

# -----------------------------------------------------------------------------
# Конфигурация модели
# -----------------------------------------------------------------------------

# Путь к базовой модели (ID Hugging Face или локальный путь)
# Примеры:
#   - Hugging Face: mistralai/Mistral-Small-24B-Instruct-2501
#   - Локальный: /mnt/models/mistral-small-24b
MODEL_PATH=mistralai/Mistral-Small-24B-Instruct-2501

# Путь к LoRA-адаптерам (опционально, оставьте пустым для только базовой модели)
# Пример: ./lora-tutors-adapter
ADAPTER_PATH=

# Токен Hugging Face (требуется для приватных или gated моделей)
# Получите токен: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# Конфигурация логирования
# -----------------------------------------------------------------------------

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к файлу логов (опционально, по умолчанию tutor.log)
LOG_FILE=tutor.log

# -----------------------------------------------------------------------------
# Конфигурация инференса
# -----------------------------------------------------------------------------

# Максимальное количество токенов для генерации в одном запросе
MAX_TOKENS=512

# Температура сэмплирования (0.1 - 2.0, ниже = более детерминированно)
TEMPERATURE=0.7

# Порог nucleus (top-p) сэмплирования
TOP_P=0.9

# Top-k сэмплирование (0 = отключено)
TOP_K=50

# -----------------------------------------------------------------------------
# Конфигурация GPU
# -----------------------------------------------------------------------------

# Максимальная память на GPU (опционально)
# Пример: {"0": "20GB", "1": "20GB"}
MAX_MEMORY=

# Стратегия размещения устройств: auto, cuda, cpu
DEVICE_MAP=auto

# -----------------------------------------------------------------------------
# Конфигурация API (для будущей интеграции)
# -----------------------------------------------------------------------------

# Хост и порт API
API_HOST=0.0.0.0
API_PORT=8000

# Подключение Redis для очереди задач (Celery)
REDIS_URL=redis://localhost:6379/0

# Ограничение частоты запросов (запросов в минуту)
RATE_LIMIT=60

# -----------------------------------------------------------------------------
# Интеграция с Moodle (для будущего использования)
# -----------------------------------------------------------------------------

# URL сайта Moodle
MOODLE_URL=

# Токен Web Service Moodle
MOODLE_TOKEN=

# -----------------------------------------------------------------------------
# Безопасность
# -----------------------------------------------------------------------------

# Секретный ключ для аутентификации API
SECRET_KEY=ваш-секретный-ключ-замените-это

# Разрешённые источники CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
