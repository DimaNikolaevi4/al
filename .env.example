# =============================================================================
# AI Tutor SPO - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------

# Path to the base model (Hugging Face ID or local path)
# Examples:
#   - Hugging Face: mistralai/Mistral-Small-24B-Instruct-2501
#   - Local: /mnt/models/mistral-small-24b
MODEL_PATH=mistralai/Mistral-Small-24B-Instruct-2501

# Path to LoRA adapters (optional, leave empty for base model only)
# Example: ./lora-tutors-adapter
ADAPTER_PATH=

# Hugging Face token (required for private or gated models)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, defaults to tutor.log)
LOG_FILE=tutor.log

# -----------------------------------------------------------------------------
# Inference Configuration
# -----------------------------------------------------------------------------

# Maximum tokens to generate in a single request
MAX_TOKENS=512

# Sampling temperature (0.1 - 2.0, lower = more deterministic)
TEMPERATURE=0.7

# Top-p (nucleus) sampling threshold
TOP_P=0.9

# Top-k sampling (0 = disabled)
TOP_K=50

# -----------------------------------------------------------------------------
# GPU Configuration
# -----------------------------------------------------------------------------

# Maximum memory per GPU (optional)
# Example: {"0": "20GB", "1": "20GB"}
MAX_MEMORY=

# Device map strategy: auto, cuda, cpu
DEVICE_MAP=auto

# -----------------------------------------------------------------------------
# API Configuration (for future integration)
# -----------------------------------------------------------------------------

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Redis connection for task queue (Celery)
REDIS_URL=redis://localhost:6379/0

# Rate limiting (requests per minute)
RATE_LIMIT=60

# -----------------------------------------------------------------------------
# Moodle Integration (for future use)
# -----------------------------------------------------------------------------

# Moodle site URL
MOODLE_URL=

# Moodle Web Service token
MOODLE_TOKEN=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Secret key for API authentication
SECRET_KEY=your-secret-key-change-this

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
